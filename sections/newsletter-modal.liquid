{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter-modal.css' | asset_url | stylesheet_tag }}

<newsletter-modal
  class="newsletter-modal-host"
  data-customer-logged-in="{% if customer %}true{% else %}false{% endif %}"
  data-template="{{ template.name }}"
  data-delay="{{ section.settings.auto_show_delay }}"
>
  <div class="shopify-section">
    <modal-dialog id="NewsletterModal" class="newsletter-modal product-popup-modal">
      <div
        role="dialog"
        aria-labelledby="NewsletterModalHeading"
        aria-modal="true"
        class="newsletter-modal__content product-popup-modal__content color-{{ section.settings.color_scheme }} gradient"
        tabindex="-1"
      >
        <button
          id="ModalClose-newsletter"
          type="button"
          class="newsletter-modal__close product-popup-modal__toggle"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          <span class="svg-wrapper">
            {{- 'icon-close.svg' | inline_asset_content -}}
          </span>
        </button>

        <div class="newsletter-modal__inner">
          {%- if section.settings.heading != blank -%}
            <h2 id="NewsletterModalHeading" class="newsletter-modal__heading inline-richtext h1">
              {{ section.settings.heading }}
            </h2>
          {%- endif -%}

          {%- if section.settings.text != blank -%}
            <div class="newsletter-modal__subheading rte">
              {{ section.settings.text }}
            </div>
          {%- endif -%}

          {% form 'customer', id: 'NewsletterModalForm', class: 'newsletter-form newsletter-form--modal js-newsletter-ajax' %}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div hidden data-newsletter-icons>
              <span data-icon-success class="svg-wrapper">
                {{- 'icon-success.svg' | inline_asset_content -}}
              </span>
              <span data-icon-error class="svg-wrapper">
                {{- 'icon-error.svg' | inline_asset_content -}}
              </span>
            </div>
            <div data-newsletter-fields class="newsletter-form__field-wrapper">
              <div class="field">
                <input
                  id="NewsletterModalEmail"
                  type="email"
                  name="contact[email]"
                  class="field__input"
                  aria-required="true"
                  autocorrect="off"
                  autocapitalize="off"
                  autocomplete="email"
                  placeholder="{{ 'newsletter.label' | t }}"
                  required
                >
                <label class="field__label" for="NewsletterModalEmail">
                  {{ 'newsletter.label' | t }}
                </label>
                <button
                  type="submit"
                  class="newsletter-form__button field__button"
                  name="commit"
                  aria-label="{{ 'newsletter.button_label' | t }}"
                >
                  <span class="svg-wrapper">
                    {{- 'icon-arrow.svg' | inline_asset_content -}}
                  </span>
                </button>
              </div>
            </div>
            <div data-newsletter-feedback hidden></div>
          {% endform %}
        </div>
      </div>
    </modal-dialog>
  </div>
</newsletter-modal>

<script src="{{ 'newsletter-modal.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Newsletter modal",
  "tag": "section",
  "class": "section-newsletter-modal",
  "settings": [
    {
      "type": "paragraph",
      "content": "Shows on product pages for guests every 12 hours. Logged-in customers never see the auto popup."
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Subscribe to our emails"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description",
      "default": "<p>Be the first to know about new collections and exclusive offers.</p>"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "auto_show_delay",
      "min": 0,
      "max": 15,
      "step": 1,
      "unit": "sec",
      "label": "Auto-show delay on product pages",
      "default": 3,
      "info": "Delay before the modal appears on product pages."
    }
  ]
}
{% endschema %}
