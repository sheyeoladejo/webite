{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}

{%- assign accent_grey = settings.color_accent_grey | default: '#D5D0CD' -%}
{%- style -%}
  .footer-custom-{{ section.id }} {
    border-top: 1px solid {{ accent_grey }};
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .footer-custom-{{ section.id }} {
      margin-top: {{ section.settings.margin_top }}px;
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<footer class="footer footer-custom-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width footer-custom__inner">
    <div class="footer-custom__grid">
      <div class="footer-custom__col footer-custom__col--logo">
        <div class="footer-custom__logo">
          <a href="{{ routes.root_url }}" class="footer-custom__logo-link">
            <img
              src="{{ 'logo-text-horizontal.svg' | asset_url }}"
              alt="{{ shop.name | escape }}"
              class="footer-custom__logo-img"
              width="160"
              height="24"
              loading="lazy"
              decoding="async"
            >
          </a>
        </div>
      </div>

      <div class="footer-custom__col">
        <h3 class="footer-custom__subheading">{{ section.settings.help_column_heading | escape }}</h3>
        <div class="footer-custom__group">
          <a
            href="{{ section.settings.link_consultation }}"
            class="footer-custom__link footer-custom__link__book-consultation"
          >
            {{ section.settings.label_consultation | escape }}
          </a>
          <a href="{{ section.settings.link_size_chart }}" class="footer-custom__link">
            {{- section.settings.label_size_chart | escape -}}
          </a>
          <a href="{{ section.settings.link_faq }}" class="footer-custom__link">
            {{- section.settings.label_faq | escape -}}
          </a>
          <a href="{{ section.settings.link_returns }}" class="footer-custom__link">
            {{- section.settings.label_returns | escape -}}
          </a>
          <a href="{{ section.settings.link_privacy }}" class="footer-custom__link">
            {{- section.settings.label_privacy | escape -}}
          </a>
          <a href="{{ section.settings.link_payment }}" class="footer-custom__link">
            {{- section.settings.label_payment | escape -}}
          </a>
          <a href="{{ section.settings.link_delivery }}" class="footer-custom__link">
            {{- section.settings.label_delivery | escape -}}
          </a>
        </div>
      </div>

      <div class="footer-custom__col">
        <div class="footer-custom__group">
          <h3 class="footer-custom__subheading">{{ section.settings.categories_heading | escape }}</h3>
          <a href="{{ section.settings.category_link_1 }}" class="footer-custom__link">
            {{- section.settings.category_label_1 | escape -}}
          </a>
          <a href="{{ section.settings.category_link_2 }}" class="footer-custom__link">
            {{- section.settings.category_label_2 | escape -}}
          </a>
          <a href="{{ section.settings.category_link_3 }}" class="footer-custom__link">
            {{- section.settings.category_label_3 | escape -}}
          </a>
          <a href="{{ section.settings.category_link_4 }}" class="footer-custom__link">
            {{- section.settings.category_label_4 | escape -}}
          </a>
          <a href="{{ section.settings.category_link_5 }}" class="footer-custom__link">
            {{- section.settings.category_label_5 | escape -}}
          </a>
        </div>
      </div>

      <div class="footer-custom__col">
        <div class="footer-custom__group">
          <p class="footer-custom__subheading">{{ section.settings.contact_subheading | escape }}</p>
          <p class="footer-custom__text">
            {{ section.settings.label_email_prefix | escape }}:
            <a href="mailto:{{ section.settings.email }}" class="footer-custom__link footer-custom__link--inline">
              {{- section.settings.email -}}
            </a>
          </p>
          <p class="footer-custom__text">
            {{ section.settings.label_whatsapp_prefix | escape }}:
            <a
              href="https://wa.me/{{ section.settings.whatsapp_number | remove: ' ' | remove: '+' }}"
              class="footer-custom__link footer-custom__link--inline"
              target="_blank"
              rel="noopener"
            >
              {{- section.settings.whatsapp_number -}}
            </a>
          </p>
          <p class="footer-custom__text">
            {{ section.settings.label_instagram_prefix | escape }}:
            <a
              href="{{ section.settings.instagram_url }}"
              class="footer-custom__link footer-custom__link--inline"
              target="_blank"
              rel="noopener"
            >
              {{- section.settings.instagram_display | escape -}}
            </a>
          </p>
        </div>

        {% comment %}
          <div class="footer-custom__locale">
            <p class="footer-custom__subheading">Change Delivery Country</p>
            {%- if localization.available_countries.size > 1 -%}
              <localization-form>
                {%- form 'localization',
                  id: 'FooterCountryForm',
                  class: 'localization-form footer-custom__localization-form'
                -%}
                  <div>
                    <h2 class="visually-hidden" id="FooterCountryLabel">{{ 'localization.country_label' | t }}</h2>
                    {%- render 'country-localization', localPosition: 'FooterCountry' -%}
                  </div>
                {%- endform -%}
              </localization-form>
            {%- else -%}
              <p class="footer-custom__text">{{ localization.country.name | default: 'United States' }}</p>
            {%- endif -%}

            <p class="footer-custom__subheading" style="margin-top: 1rem;">Change Language</p>
            {%- if localization.available_languages.size > 1 -%}
              <localization-form>
                {%- form 'localization',
                  id: 'FooterLanguageForm',
                  class: 'localization-form footer-custom__localization-form'
                -%}
                  <div>
                    <h2 class="visually-hidden" id="FooterLanguageLabel">{{ 'localization.language_label' | t }}</h2>
                    {%- render 'language-localization', localPosition: 'FooterLanguage' -%}
                  </div>
                {%- endform -%}
              </localization-form>
            {%- else -%}
              <p class="footer-custom__text">
                {{ localization.language.endonym_name | capitalize | default: 'English' }}
              </p>
            {%- endif -%}
          </div>
        {% endcomment %}
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-custom__inner {
    max-width: 1920px;
    margin: 0 auto;
    padding: 0 1rem;
  }
  @media screen and (min-width: 768px) {
    .footer-custom__inner {
      padding: 0 2.5rem;
    }
  }
  .footer-custom__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  @media screen and (min-width: 990px) {
    .footer-custom__grid {
      grid-template-columns: minmax(120px, 0.6fr) minmax(200px, 1fr) minmax(180px, 0.9fr) minmax(260px, 1.1fr);
      column-gap: 3rem;
      align-items: start;
    }
  }
  .footer-custom__heading {
    margin: 0 0 1.5rem;
    font-size: 14px;
    line-height: 1.2;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground));
  }
  .footer-custom__group {
    margin-bottom: 1.2rem;
  }
  .footer-custom__subheading {
    margin: 0 0 0.4rem;
    font-size: 15px;
    font-weight: 700;
    line-height: 1.4;
    color: rgb(var(--color-foreground));
  }
  .footer-custom__text {
    margin: 0 0 0.3rem;
    font-size: 15px;
    line-height: 1.45;
    color: rgb(var(--color-foreground));
  }
  .footer-custom__link {
    display: block;
    margin: 0 0 0.2rem;
    text-decoration: none;
    font-size: 15px;
    line-height: 1.45;
    color: rgb(var(--color-foreground));
  }
  .footer-custom__link:hover {
    text-decoration: underline;
  }
  .footer-custom__social {
    margin: 0.8rem 0 1rem;
  }
  .footer-custom__social .list-social {
    justify-content: flex-start;
    gap: 0.9rem;
  }
  .footer-custom__locale {
    margin-top: 0.2rem;
  }
  {% comment %} .footer-custom__link__book-consultation {
    text-transform: uppercase;
  } {% endcomment %}
  .footer-custom__col--logo {
    display: flex;
    align-items: flex-start;
  }
  .footer-custom__logo-link {
    display: block;
  }
  .footer-custom__logo-img {
    max-width: 160px;
    height: auto;
    display: block;
  }
  .footer-custom__logo-placeholder {
    width: 160px;
    min-height: 80px;
    background: rgba(var(--color-foreground), 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  .footer-custom__logo-placeholder-text {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: rgba(var(--color-foreground), 0.4);
    text-transform: uppercase;
  }
  .footer-custom__link--inline {
    display: inline;
  }
  .footer-custom__localization-form .disclosure__button {
    font-size: 15px;
  }
</style>

