{%- if section.blocks.size < 1 -%}
  {%- if request.design_mode -%}
    <div class="color-{{ section.settings.color_scheme | default: 'scheme-1' }} gradient page-width">
      <p class="caption">Add testimonials in the section settings.</p>
    </div>
  {%- endif -%}
{%- else -%}
  {{ 'section-testimonials-carousel.css' | asset_url | stylesheet_tag }}

  {%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }

    @media screen and (min-width: 768px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
  {%- endstyle -%}

  <div class="color-{{ section.settings.color_scheme }} isolate gradient">
    <section
      class="testimonials-carousel section-{{ section.id }}-padding"
      id="testimonials-carousel-{{ section.id }}"
      data-testimonials-carousel
      data-speed="{{ section.settings.speed_px_per_sec | default: 48 }}"
    >
      <div class="page-width testimonials-carousel__page">
        <div class="collection__title title-wrapper title-wrapper--no-top-margin">
          {%- if section.settings.title != blank -%}
            <h2
              class="title inline-richtext {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            >
              {{ section.settings.title }}
            </h2>
          {%- endif -%}
        </div>

        <div
          class="testimonials-carousel__viewport"
          data-carousel-viewport
        >
          <div
            class="testimonials-carousel__track testimonials-carousel__track--animated"
            data-carousel-track
            id="carousel-track-{{ section.id }}"
          >
            {%- for pass in (1..2) -%}
              {%- for block in section.blocks -%}
                <article
                  class="testimonials-carousel__slide"
                  {% if pass == 1 %}
                    {{ block.shopify_attributes }}
                  {% else %}
                    aria-hidden="true"
                  {% endif %}
                >
                  <div class="testimonials-carousel__body">
                    <div
                      class="testimonials-carousel__quote rte"
                      lang="{{ request.locale.iso_code | default: 'en' }}"
                    >
                      {{- block.settings.quote | strip | escape | newline_to_br -}}
                    </div>
                  </div>
                  {%- if block.settings.name != blank -%}
                    <div class="testimonials-carousel__spacer" aria-hidden="true"></div>
                    <div class="testimonials-carousel__footer">
                      <p class="testimonials-carousel__name">{{ block.settings.name | escape }}</p>
                    </div>
                  {%- endif -%}
                </article>
              {%- endfor -%}
            {%- endfor -%}
          </div>
        </div>
      </div>
    </section>
  </div>

  <script>
    (() => {
      const setupTrack = (root) => {
        if (!root || !root.hasAttribute('data-testimonials-carousel')) return;

        const track = root.querySelector('[data-carousel-track]');
        if (!track) return;

        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          track.classList.remove('testimonials-carousel__track--animated');
          track.style.removeProperty('--carousel-duration');
          if (root._carouselResize) {
            root._carouselResize.disconnect();
            root._carouselResize = null;
          }
          return;
        }

        const speed = parseFloat(String(root.getAttribute('data-speed') || '48').trim()) || 48;
        const setDuration = () => {
          const half = track.scrollWidth / 2;
          if (half < 1) return;
          const sec = half / speed;
          track.classList.add('testimonials-carousel__track--animated');
          track.style.setProperty('--carousel-duration', sec + 's');
        };

        setDuration();

        if (root._carouselResize) {
          root._carouselResize.disconnect();
        }
        const ro = new ResizeObserver(() => {
          setDuration();
        });
        ro.observe(track);
        root._carouselResize = ro;
      };

      const init = (container) => {
        if (!container) return;
        if (container.matches && container.matches('[data-testimonials-carousel]')) {
          setupTrack(container);
        }
        if (container.querySelectorAll) {
          container.querySelectorAll('[data-testimonials-carousel]').forEach((n) => setupTrack(n));
        }
      };

      if (document.readyState === 'loading') {
        document.addEventListener(
          'DOMContentLoaded',
          function () {
            init(document);
          },
          { once: true }
        );
      } else {
        init(document);
      }

      document.addEventListener('shopify:section:load', (event) => {
        init(event.target);
      });
    })();
  </script>

  <style>
    #testimonials-carousel-{{ section.id }} [data-carousel-track].testimonials-carousel__track--animated {
      animation-duration: var(--carousel-duration, 45s);
    }
  </style>
{%- endif -%}

{% schema %}
{
  "name": "Testimonials carousel",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "TESTIMONIALS"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" },
        { "value": "hxl", "label": "Extra large" },
        { "value": "hxxl", "label": "Extra extra large" }
      ],
      "default": "h2"
    },
    {
      "type": "range",
      "id": "speed_px_per_sec",
      "min": 12,
      "max": 120,
      "step": 4,
      "label": "Scroll speed (pixels per second)",
      "default": 48
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "text", "id": "name", "label": "Name", "default": "Mira Yaache" },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "From a sketch to a dream come true! I highly recommend Sheye Oladejo for all your fabulous dress needs."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials carousel",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
