{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-moment-card.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign mg_section_id = section.id
  assign mg_color_scheme = section.settings.color_scheme | default: 'scheme-1'
  assign mg_pad_top = section.settings.padding_top | default: 36
  assign mg_pad_bottom = section.settings.padding_bottom | default: 36
  assign mg_heading_size = section.settings.heading_size | default: 'h1'
-%}

{%- style -%}
  .section-{{ mg_section_id }}-padding {
    padding-top: {{ mg_pad_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ mg_pad_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 768px) {
    .section-{{ mg_section_id }}-padding {
      padding-top: {{ mg_pad_top }}px;
      padding-bottom: {{ mg_pad_bottom }}px;
    }
  }

  #collection-{{ mg_section_id }} .collection__title {
    text-align: center;
    text-transform: uppercase;
  }

  /*
   Moments grid: real CSS Grid (not theme flex .grid) so orphans stay one column wide.
   <640px: 1 column. ≥640px: 2 equal columns; last row with a single item does not stretch.
  */
  #collection-{{ mg_section_id }} .moments-grid__list.grid {
    display: grid;
    width: 100%;
    margin-bottom: 2rem;
    padding: 0;
    list-style: none;
    flex-wrap: unset;
    column-gap: var(--grid-mobile-horizontal-spacing);
    row-gap: var(--grid-mobile-vertical-spacing);
    grid-template-columns: minmax(0, 1fr);
    justify-content: initial;
  }

  #collection-{{ mg_section_id }} .moments-grid__list.grid:last-child {
    margin-bottom: 0;
  }

  @media screen and (min-width: 640px) {
    #collection-{{ mg_section_id }} .moments-grid__list.grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: var(--grid-desktop-horizontal-spacing);
      row-gap: var(--grid-desktop-vertical-spacing);
    }
  }

  #collection-{{ mg_section_id }} .moments-grid__list .grid__item {
    width: 100%;
    max-width: none;
    flex-grow: 0;
    flex-shrink: 0;
    min-width: 0;
  }

  #collection-{{ mg_section_id }} .card__heading,
  #collection-{{ mg_section_id }} .card__heading a {
    text-transform: uppercase;
    text-align: left;
  }

  @media screen and (min-width: 640px) {
    #collection-{{ mg_section_id }} .card__heading,
    #collection-{{ mg_section_id }} .card__heading a {
      text-align: center;
    }
  }

  #collection-{{ mg_section_id }} .moments-grid__empty {
    padding: 3rem 1rem;
    color: rgba(var(--color-foreground), 1);
  }
{%- endstyle -%}

<div class="color-{{ mg_color_scheme }} isolate gradient">
  <div
    class="collection section-{{ mg_section_id }}-padding"
    id="collection-{{ mg_section_id }}"
    data-id="{{ mg_section_id }}"
  >
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="collection__title title-wrapper title-wrapper--no-top-margin page-width">
        {%- if section.settings.heading != blank -%}
          <h2 class="title inline-richtext {{ mg_heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
            {{ section.settings.heading | escape }}
          </h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <div class="collection__description body rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
            {{ section.settings.subheading | escape }}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size == 0 -%}
      <div class="moments-grid__empty center page-width">
        <p>Add moment cards in the theme editor (“Add block”).</p>
      </div>
    {%- else -%}
      <div
        class="product-grid-container{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %} page-width"
        {% if settings.animations_reveal_on_scroll %}
          data-cascade
        {% endif %}
      >
        <ul
          id="Slider-{{ mg_section_id }}"
          data-id="{{ mg_section_id }}"
          class="
            grid product-grid moments-grid__list contains-card contains-card--product{% if settings.card_style == 'standard' %} contains-card--standard{% endif %}
            {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}
          "
          role="list"
        >
          {%- assign moment_card_index = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type != 'moment_card' -%}
              {%- continue -%}
            {%- endif -%}

            {%- assign moment_card_index = moment_card_index | plus: 1 -%}
            {%- assign card_image = block.settings.image -%}
            {%- assign title_setting = block.settings.title | strip -%}
            {%- assign tag_setting = block.settings.tag | strip -%}
            {%- assign link_setting = block.settings.link | strip -%}

            {%- assign card_title = title_setting -%}
            {%- if card_title == blank and tag_setting != blank -%}
              {%- assign card_title = tag_setting | replace: '_', ' ' | replace: '-', ' ' -%}
            {%- elsif card_title == blank -%}
              {%- assign card_title = 'Moment' -%}
            {%- endif -%}

            {%- assign lazy_load = false -%}
            {%- if moment_card_index > 2 -%}
              {%- assign lazy_load = true -%}
            {%- endif -%}

            <li
              class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
              {{ block.shopify_attributes }}
              {% if settings.animations_reveal_on_scroll %}
                data-cascade
                style="--animation-order: {{ moment_card_index }};"
              {% endif %}
            >
              {% render 'moment-tag-card',
                title: card_title,
                tag: tag_setting,
                card_link: link_setting,
                card_image: card_image,
                section_id: mg_section_id,
                card_index: moment_card_index,
                lazy_load: lazy_load,
                skip_styles: true,
                media_aspect_ratio: section.settings.image_ratio,
                image_sizes_column_divisor: 2
              %}
            </li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Moments grid",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Moments"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" },
        { "value": "hxl", "label": "Extra large" },
        { "value": "hxxl", "label": "Extra extra large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        { "value": "adapt", "label": "Adapt to image" },
        { "value": "portrait", "label": "Portrait" },
        { "value": "square", "label": "Square" }
      ],
      "default": "adapt",
      "label": "Image ratio",
      "info": "Matches featured collection card image behavior."
    },
    {
      "type": "paragraph",
      "content": "Add cards with “Add block”. Two columns from 640px width; one column below. A single item on the last row stays half-width."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "moment_card",
      "name": "Moment card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Moment"
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Product tag",
          "info": "Optional. Builds a link to the all-products collection filtered by this tag (e.g. wedding_dresses). Ignored if “Link” is set."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "info": "Optional. Use a custom URL instead of the tag-based collection link."
        }
      ]
    }
  ],
  "max_blocks": 48,
  "presets": [
    {
      "name": "Moments grid"
    }
  ]
}
{% endschema %}
