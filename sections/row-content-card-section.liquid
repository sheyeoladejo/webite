{{ 'section-about-founder-shared.css' | asset_url | stylesheet_tag }}
{{ 'row-content-card.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .row-content-card-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .row-content-card-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section
  class="about-founder row-content-card-section row-content-card-section-{{ section.id }} color-{{ section.settings.color_scheme }} gradient"
  aria-labelledby="row-content-card-heading-{{ section.id }}"
>
  {% render 'row-content-card',
    image: section.settings.image,
    heading: section.settings.heading,
    body: section.settings.body,
    attribution: section.settings.attribution,
    button_link: section.settings.button_link,
    button_label: section.settings.button_label,
    reverse_layout: section.settings.reverse_layout,
    unique_id: section.id
  %}
</section>

{% schema %}
{
  "name": "Row content card",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "A STORY OF SOLIDARITY"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "OluwaSheye Oladejo founded SheyeOladejo with a vision of creating a more equitable future, where craftsmanship, personal connection, and sustainability are at the heart of every piece.\n\nSince its founding, we have been dedicated to offering exceptional quality and a personalized experience for every client.\n\nDiscover more about our story and values."
    },
    {
      "type": "text",
      "id": "attribution",
      "label": "Attribution"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Read more",
      "info": "Shown when a button link is set."
    },
    {
      "type": "checkbox",
      "id": "reverse_layout",
      "label": "Reverse layout",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 128,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 128,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 48
    }
  ]
}
{% endschema %}
