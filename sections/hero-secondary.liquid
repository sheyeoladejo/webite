{%- assign primary_dark = settings.color_primary | default: '#1D1D1B' -%}
{%- style -%}
  .hero-secondary-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .hero-secondary-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  .hero-secondary-{{ section.id }} .hero-secondary__heading {
    color: {{ primary_dark }};
  }
{%- endstyle -%}

{{ 'component-breadcrumbs.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign hero_inner_layout = section.settings.inner_layout | default: 'theme'
  assign only_page_handle = section.settings.only_page_handle | strip
  assign should_render_section = true
  assign resolved_heading = section.settings.heading | strip
  if only_page_handle != blank
    if page == blank or page.handle != only_page_handle
      assign should_render_section = false
    endif
  endif
  if product != blank
    assign breadcrumb_template_type = 'product'
  elsif collection != blank
    assign breadcrumb_template_type = 'collection'
  elsif page != blank
    assign breadcrumb_template_type = 'page'
  else
    assign breadcrumb_template_type = 'collection'
  endif
  if resolved_heading == blank
    if collection != blank
      assign resolved_heading = collection.title
    elsif page != blank
      assign resolved_heading = page.title
    elsif product != blank
      assign resolved_heading = product.title
    else
      assign resolved_heading = 'A STORY OF SOLIDARITY'
    endif
  endif
-%}

{%- if should_render_section -%}
<div class="hero-secondary__section hero-secondary-{{ section.id }}">
  {%- if hero_inner_layout == 'page' -%}
    <div class="hero-secondary__page-shell">
      <div class="hero-secondary__page-inner">
  {%- else -%}
    <div class="page-width">
  {%- endif -%}
  {%- unless section.settings.show_breadcrumbs == false -%}
    {% render 'breadcrumbs',
      template_type: breadcrumb_template_type,
      product: product,
      collection: collection,
      page: page,
      current_title: resolved_heading,
      class: 'breadcrumbs breadcrumbs--hero-secondary'
    %}
  {%- endunless -%}
  {%- if hero_inner_layout != 'page' -%}
    </div>
  {%- endif -%}

  <section
    class="hero-secondary"
    aria-labelledby="hero-secondary-heading-{{ section.id }}"
  >
    <div class="hero-secondary__media">
      {%- if section.settings.video != blank -%}
        {{
          section.settings.video
          | video_tag:
            image_size: '1920x',
            autoplay: true,
            loop: true,
            controls: false,
            muted: true,
            class: 'hero-secondary__video'
        }}
      {%- elsif section.settings.video_url != blank -%}
        {%- liquid
          assign video_id = section.settings.video_url.id
          if section.settings.video_url.type == 'youtube'
            assign video_src = 'https://www.youtube.com/embed/' | append: video_id | append: '?autoplay=1&mute=1&loop=1&playlist=' | append: video_id | append: '&controls=0&showinfo=0&rel=0'
          else
            assign video_src = 'https://player.vimeo.com/video/' | append: video_id | append: '?autoplay=1&muted=1&loop=1&background=1'
          endif
        -%}
        <iframe
          class="hero-secondary__iframe"
          src="{{ video_src }}"
          allow="autoplay; encrypted-media"
          allowfullscreen
          title="{{ section.settings.heading | escape }}"
        ></iframe>
      {%- elsif section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1920
          | image_tag: loading: 'eager', class: 'hero-secondary__image', sizes: '100vw', widths: '750, 1100, 1500, 1920'
        }}
      {%- endif -%}
    </div>

    <div class="hero-secondary__content">
      <h1 id="hero-secondary-heading-{{ section.id }}" class="hero-secondary__heading">
        {{ resolved_heading | escape }}
      </h1>
    </div>
  </section>

  {%- if hero_inner_layout == 'page' -%}
    </div>
    </div>
  {%- endif -%}
</div>
{%- endif -%}

<style>
  .hero-secondary__page-inner {
    max-width: 1440px;
    margin-left: auto;
    margin-right: auto;
    padding-left: 1rem;
    padding-right: 1rem;
  }
  @media screen and (min-width: 768px) {
    .hero-secondary__page-inner {
      padding-left: 2.5rem;
      padding-right: 2.5rem;
    }
  }
  .hero-secondary__page-inner .breadcrumbs {
    padding-left: 0;
    padding-right: 0;
  }
  .hero-secondary__section {
    width: 100%;
  }
  .hero-secondary {
    position: relative;
    min-height: 40vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .hero-secondary__media {
    position: absolute;
    inset: 0;
  }
  .hero-secondary__video,
  .hero-secondary__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-secondary__iframe {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100vw;
    height: 56.25vw;
    min-height: 100%;
    min-width: 177.78vh;
    transform: translate(-50%, -50%);
    object-fit: cover;
  }
  .hero-secondary__content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 2rem 1.5rem;
  }
  .hero-secondary__heading {
    font-family: var(--font-heading-family);
    font-size: clamp(1.75rem, 5vw, 3rem);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0;
    line-height: 1.2;
  }
</style>

{% schema %}
{
  "name": "Hero secondary",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "A STORY OF SOLIDARITY"
    },
    {
      "type": "select",
      "id": "inner_layout",
      "label": "Content width",
      "options": [
        {
          "value": "theme",
          "label": "Theme default (page width)"
        },
        {
          "value": "page",
          "label": "Page hero (max 1440px, padded)"
        }
      ],
      "default": "theme"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumbs",
      "label": "Show breadcrumbs",
      "default": true
    },
    {
      "type": "text",
      "id": "only_page_handle",
      "label": "Only show on page handle",
      "info": "Leave blank to show everywhere this section is added."
    },
    {
      "type": "header",
      "content": "Background media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image (used if no video set)"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video (uploaded). Loops without sound or controls."
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "Video URL (YouTube or Vimeo). Loops without controls.",
      "accept": ["youtube", "vimeo"]
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 128,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 128,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Hero secondary"
    }
  ]
}
{% endschema %}
