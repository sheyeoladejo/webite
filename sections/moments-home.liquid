{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-article-card.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign mh_section_id = section.id
  assign mh_blog = section.settings.blog
  assign mh_color_scheme = section.settings.color_scheme | default: 'scheme-1'
  assign mh_heading_size = section.settings.heading_size | default: 'h2'
  assign mh_pad_top = section.settings.padding_top | default: 64
  assign mh_pad_bottom = section.settings.padding_bottom | default: 64
-%}

{%- style -%}
  .section-{{ mh_section_id }}-padding {
    padding-top: {{ mh_pad_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ mh_pad_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 768px) {
    .section-{{ mh_section_id }}-padding {
      padding-top: {{ mh_pad_top }}px;
      padding-bottom: {{ mh_pad_bottom }}px;
    }
  }

  #moments-home-{{ mh_section_id }} .collection__title {
    text-align: center;
    text-transform: uppercase;
  }

  #moments-home-{{ mh_section_id }} .moments-grid__list.grid {
    display: grid;
    width: 100%;
    margin-bottom: 2rem;
    padding: 0;
    list-style: none;
    flex-wrap: unset;
    column-gap: var(--grid-mobile-horizontal-spacing);
    row-gap: var(--grid-mobile-vertical-spacing);
    grid-template-columns: minmax(0, 1fr);
    justify-content: initial;
  }

  #moments-home-{{ mh_section_id }} .moments-grid__list.grid:last-child {
    margin-bottom: 0;
  }

  @media screen and (min-width: 640px) {
    #moments-home-{{ mh_section_id }} .moments-grid__list.grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: var(--grid-desktop-horizontal-spacing);
      row-gap: var(--grid-desktop-vertical-spacing);
    }
  }

  #moments-home-{{ mh_section_id }} .moments-grid__list .grid__item {
    width: 100%;
    max-width: none;
    flex-grow: 0;
    flex-shrink: 0;
    min-width: 0;
  }

  #moments-home-{{ mh_section_id }} .card__heading,
  #moments-home-{{ mh_section_id }} .card__heading a {
    text-transform: uppercase;
    text-align: left;
  }

  @media screen and (min-width: 640px) {
    #moments-home-{{ mh_section_id }} .card__heading,
    #moments-home-{{ mh_section_id }} .card__heading a {
      text-align: center;
    }
  }

  #moments-home-{{ mh_section_id }} .card--stacked-product > .card__content .card__heading a {
    padding-left: 0;
    padding-right: 0;
  }
{%- endstyle -%}

<div class="color-{{ mh_color_scheme }} isolate gradient">
  <div
    class="collection section-{{ mh_section_id }}-padding"
    id="moments-home-{{ mh_section_id }}"
    data-id="{{ mh_section_id }}"
  >
    <div class="collection__title title-wrapper title-wrapper--no-top-margin page-width">
      {%- if section.settings.heading != blank -%}
        <h2 class="title inline-richtext {{ mh_heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          {{ section.settings.heading | escape }}
        </h2>
      {%- endif -%}
    </div>

    <div
      class="product-grid-container{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %} page-width"
      {% if settings.animations_reveal_on_scroll %}
        data-cascade
      {% endif %}
    >
      {%- if mh_blog != blank and mh_blog.articles.size > 0 -%}
        <ul
          id="MomentsHomeGrid-{{ mh_section_id }}"
          class="
            grid product-grid moments-grid__list contains-card contains-card--product{% if settings.card_style == 'standard' %} contains-card--standard{% endif %}
            {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}
          "
          role="list"
        >
          {%- for article in mh_blog.articles limit: 2 -%}
            <li
              class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
              {% if settings.animations_reveal_on_scroll %}
                data-cascade
                style="--animation-order: {{ forloop.index }};"
              {% endif %}
            >
              {% render 'article-card',
                blog: mh_blog,
                article: article,
                show_image: section.settings.show_image,
                show_date: section.settings.show_date,
                show_author: section.settings.show_author,
                show_excerpt: true,
                stacked_layout: true,
                lazy_load: false
              %}
            </li>
          {%- endfor -%}
        </ul>
      {%- elsif request.design_mode -%}
        <div class="main-blog__empty center">
          <p>{{ 'blogs.article.no_posts' | t }}</p>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Moments home",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "MOMENTS"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" },
        { "value": "hxl", "label": "Extra large" },
        { "value": "hxxl", "label": "Extra extra large" }
      ],
      "default": "h2",
      "label": "Heading size"
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "default": true,
      "label": "Show image"
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "default": true,
      "label": "Show date"
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "default": false,
      "label": "Show author"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 128,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 128,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Moments home"
    }
  ]
}
{% endschema %}
