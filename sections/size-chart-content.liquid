              </tr>
              <tr>
                <th scope="row">16</th>
                <td>12</td>
                <td>16</td>
                <td>44</td>
                <td>48</td>
              </tr>
              <tr>
                <th scope="row">18</th>
                <td>14</td>
                <td>18</td>
                <td>46</td>
                <td>50</td>
              </tr>
              <tr>
                <th scope="row">20</th>
                <td>16</td>
                <td>20</td>
                <td>48</td>
                <td>52</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <div class="size-chart-content__group">
        <h3 class="size-chart-content__table-title">Letter sizes</h3>
        <div class="size-chart-content__table-wrap">
          <table class="size-chart-content__table">
            <caption class="visually-hidden">
              Letter size conversion for Small, Medium, and Large.
            </caption>
            <thead>
              <tr>
                <th scope="col">Small (S)</th>
                <th scope="col">Medium (M)</th>
                <th scope="col">Large (L)</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>6</td>
                <td>12</td>
                <td>16</td>
              </tr>
              <tr>
                <td>8</td>
                <td>14</td>
                <td>18</td>
              </tr>
              <tr>
                <td>10</td>
                <td></td>
                <td>20</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Size chart content",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Size chart"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Intro text",
      "default": "Some styles may run True-to-size/Run-Large/Run-Small.\n\nPlease check product description or product specific size guide if there may be style specific size variation or you can also call customer care for sizing assistance."
    },
    {
      "type": "text",
      "id": "only_page_handle",
      "label": "Only show on page handle",
      "info": "Leave blank to show everywhere this section is added."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 128,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 128,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 96
    }
  ],
  "presets": [
    {
      "name": "Size chart content"
    }
  ]
}
{% endschema %}
