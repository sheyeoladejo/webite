{%- comment -%}
  Row content card: image, title, description, optional link.
  Parameters:
  - image: image object (optional)
  - heading: string (optional)
  - body: string (optional; newline-separated paragraphs)
  - attribution: string (optional)
  - link: URL string (optional; wraps row in a single link when set)
  - button_link: URL string (optional; shows a button at the end of the text)
  - button_label: string (optional; defaults to "Read more" when button_link is set)
  - reverse_layout: boolean (optional)
  - unique_id: string (required for unique heading id)
{%- endcomment -%}
{%- liquid
  assign uid = unique_id | default: 'card'
  assign heading_id = 'row-content-card-heading-' | append: uid
  assign heading_out = heading
  assign use_full_row_link = false
  if link != blank and button_link == blank
    assign use_full_row_link = true
  endif
-%}
<div class="row-content-card about-founder__inner page-width">
  {%- if use_full_row_link -%}
    <a href="{{ link }}" class="about-founder__link">
  {%- endif -%}
  <div class="about-founder__grid{% if reverse_layout %} about-founder__grid--reverse{% endif %}">
    <div class="about-founder__media about-founder__media--portrait">
      {%- if link != blank and button_link != blank -%}
        <a href="{{ link }}" class="about-founder__link about-founder__media-link">
      {%- endif -%}
      {%- if image != blank -%}
        {{
          image
          | image_url: width: 900
          | image_tag:
            loading: 'lazy',
            class: 'about-founder__image',
            widths: '400, 550, 700, 900',
            sizes: '(min-width: 990px) 50vw, 100vw'
        }}
      {%- else -%}
        <div class="about-founder__placeholder">{{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}</div>
      {%- endif -%}
      {%- if link != blank and button_link != blank -%}
        </a>
      {%- endif -%}
    </div>
    <div class="about-founder__text">
      {%- if link != blank and button_link != blank -%}
        <a href="{{ link }}" class="about-founder__link about-founder__content-link">
      {%- endif -%}
      {%- if heading_out != blank -%}
        <h2 id="{{ heading_id }}" class="about-founder__heading">
          {{ heading_out | escape }}
        </h2>
      {%- endif -%}
      {%- if body != blank -%}
        <div class="about-founder__body">
          {%- assign lines = body | split: '
' -%}
          {%- for line in lines -%}
            {%- assign trimmed = line | strip -%}
            {%- if trimmed != '' -%}
              <p>{{ trimmed | escape }}</p>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
      {%- if attribution != blank -%}
        <cite class="row-content-card__attribution">{{ attribution | escape }}</cite>
      {%- endif -%}
      {%- if link != blank and button_link != blank -%}
        </a>
      {%- endif -%}
      {%- if button_link != blank -%}
        <div class="row-content-card__actions">
          <a href="{{ button_link }}" class="button button--secondary row-content-card__button">
            {{ button_label | default: 'Read more' | escape }}
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
  {%- if use_full_row_link -%}
    </a>
  {%- endif -%}
</div>
