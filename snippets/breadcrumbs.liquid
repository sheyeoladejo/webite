{%- liquid
  assign breadcrumbs_class = class | default: 'breadcrumbs'
  assign breadcrumbs_label = aria_label | default: 'Breadcrumb'
  assign about_page_url = pages.about.url | default: '/pages/about'
  assign about_page_label = pages.about.title | default: 'About'
-%}

<nav class="{{ breadcrumbs_class }} caption" aria-label="{{ breadcrumbs_label }}">
  <a href="{{ routes.root_url }}">Home</a>
  <span aria-hidden="true"> / </span>

  {%- if template_type == 'product' and product != blank -%}
    {%- comment -%}
      Only show a collection crumb when the customer arrived from that collection
      (`collection` is set). Using `product.collections.first` adds misleading crumbs
      (e.g. Frontpage / "Home page") for direct product URLs like /products/book-consultation.
    {%- endcomment -%}
    {%- if collection != blank -%}
      <a href="{{ collection.url }}">{{ collection.title | escape }}</a>
      <span aria-hidden="true"> / </span>
    {%- endif -%}
    <span>{{ product.title | escape }}</span>
  {%- elsif template_type == 'collection' and collection != blank -%}
    {%- liquid
      assign breadcrumb_tags = current_tags
      assign breadcrumb_collection_title = collection.title
      assign request_path = request.path | default: ''
      assign path_collection_handle = ''
      assign collection_path_parts = blank

      if request_path contains '/collections/'
        assign collection_path = request_path | split: '/collections/' | last
        assign collection_path_parts = collection_path | split: '/'
        assign path_collection_handle = collection_path_parts.first
      endif

      if path_collection_handle == 'all'
        assign breadcrumb_collection_title = 'Products'
      endif

      if breadcrumb_tags == blank and path_collection_handle == 'all' and collection_path_parts.size > 1
        assign tag_path = ''
        for path_part in collection_path_parts offset: 1
          if path_part != blank
            if tag_path == blank
              assign tag_path = path_part
            else
              assign tag_path = tag_path | append: '/' | append: path_part
            endif
          endif
        endfor

        if tag_path != blank
          assign breadcrumb_tags = tag_path | split: '+'
        endif
      endif
    -%}
    <a href="{{ routes.collections_url }}">Collections</a>
    <span aria-hidden="true"> / </span>
    {%- if breadcrumb_tags != blank -%}
      <a href="{{ collection.url }}">{{ breadcrumb_collection_title | escape }}</a>
      <span aria-hidden="true"> / </span>
      <span>{{ breadcrumb_tags | join: ' + ' | replace: '-', ' ' | replace: '_', ' ' | escape }}</span>
    {%- else -%}
      <span>{{ breadcrumb_collection_title | escape }}</span>
    {%- endif -%}
  {%- elsif template_type == 'article' and blog != blank and article != blank -%}
    {%- if blog.handle == 'about' or template.suffix == 'about-blog' -%}
      <a href="{{ about_page_url }}">{{ about_page_label | escape }}</a>
      <span aria-hidden="true"> / </span>
      <span>{{ article.title | escape }}</span>
    {%- else -%}
      <a href="{{ blog.url }}">{{ blog.title | escape }}</a>
      <span aria-hidden="true"> / </span>
      <span>{{ article.title | escape }}</span>
    {%- endif -%}
  {%- elsif template_type == 'blog' and blog != blank -%}
    <span>{{ blog.title | escape }}</span>
  {%- elsif page != blank and page.handle == 'about' -%}
    <a href="{{ about_page_url }}">{{ about_page_label | escape }}</a>
  {%- elsif page != blank -%}
    <span>{{ page.title | escape }}</span>
  {%- elsif current_title != blank -%}
    <span>{{ current_title | escape }}</span>
  {%- endif -%}
</nav>
