{%- assign faq_item_index = 0 -%}

{%- if section.settings.show_offering_heading -%}
  <li class="faq-grid__section-heading">
    <h2 class="faq-grid__section-title">OUR OFFERING</h2>
  </li>
{%- endif -%}

{%- if section.settings.show_offering_q1 -%}
  {%- assign faq_item_index = faq_item_index | plus: 1 -%}
  {%- assign item_id = 'faq-item-' | append: section.id | append: '-' | append: faq_item_index -%}
  <li class="faq-grid__item">
    <input
      id="{{ item_id }}"
      class="faq-grid__input"
      type="radio"
      name="faq-{{ section.id }}"
      {% if section.settings.open_first and faq_item_index == 1 %}
        checked
      {% endif %}
    >
    <label for="{{ item_id }}" class="faq-grid__question-row">
      <p class="faq-grid__question">What is the difference between the Couture and Ready-to-Wear collections?</p>
      <svg
        class="faq-grid__icon faq-grid__icon--chevron"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 20 20"
        fill="none"
        aria-hidden="true"
      >
        <path d="M5 8l5 5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </label>
    <div class="faq-grid__answer-wrap">
      <div class="faq-grid__answer rte">
        <p>
          Our Couture offering is made-to-measure, designed for bridal, occasion wear, and custom pieces created to your
          exact vision and measurements.
        </p>
        <p>
          Our Ready-to-Wear collection is designed for immediate purchase, offering refined, thoughtfully constructed
          pieces for everyday and occasion dressing, with the same attention to detail and finish.
        </p>
      </div>
    </div>
  </li>
{%- endif -%}

